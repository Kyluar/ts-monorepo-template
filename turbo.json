{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "web#check-types": {
      "dependsOn": ["@repo/vitest-config#build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test", "@repo/vitest-config#build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "passThroughEnv": ["PLAYWRIGHT_*"],
      "dependsOn": ["^build"]
    },
    "test:e2e:smoke": {
      "passThroughEnv": ["PLAYWRIGHT_*"],
      "dependsOn": ["^build"]
    }
  }
}
